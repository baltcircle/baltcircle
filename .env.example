NODE_ENV=production
PORT=5000
DATABASE_PATH=/app/data/data.db

# Yandex Maps JS API key. Consumed by Vite at build time (import.meta.env).
# Leave empty to fall back to the stylized demo map.
VITE_YANDEX_MAPS_API_KEY=

# --- SMS OTP (backend-only, runtime) ---
# Provider selector. Set to "smsru" in production to send real SMS via SMS.RU.
# Leave empty for local dev: codes are logged to the server console and echoed
# to the client instead of being sent, so no SMS quota is used.
SMS_PROVIDER=
# SMS.RU account API id (api_id). Required when SMS_PROVIDER=smsru. Keep secret.
SMSRU_API_ID=
# Optional dedicated secret used to HMAC OTP codes before storage. Falls back to
# SESSION_SECRET when unset.
OTP_SECRET=
# Session signing secret (also used for OTP hashing fallback). Set a strong
# random value in production.
SESSION_SECRET=

# --- Admin bootstrap (temporary) ---
# Comma-separated phone numbers that should be granted the admin role. Any
# format works (8…, +7…, spaced) — each is normalized like rider phones. A
# matching phone is promoted to admin on OTP verification and on user lookup.
# Leave empty in local dev: no one is auto-promoted and /admin shows no access.
# Example: ADMIN_PHONE_NUMBERS=+79001234567,+79007654321
ADMIN_PHONE_NUMBERS=

# --- T-Bank / T-Kassa acquiring (backend-only, runtime) ---
# Real card payments via T-Bank classic acquiring. ALL of these are backend-only
# runtime config — never inlined into the client bundle. Keep the terminal key
# and password SECRET (store as GitHub Actions secrets, not in the repo). When
# TBANK_TERMINAL_KEY or TBANK_PASSWORD is empty the payment endpoints return 503
# and the UI shows "Платежи настраиваются" — the app does not crash.
# Terminal key from the T-Bank merchant cabinet.
TBANK_TERMINAL_KEY=
# Terminal password from the T-Bank merchant cabinet. SECRET — used only to sign
# requests/verify notifications (SHA-256 token). Never logged or sent to clients.
TBANK_PASSWORD=
# API base for classic acquiring. Defaults to the production host when empty.
# Use the test host for sandbox testing.
TBANK_API_BASE=https://securepay.tinkoff.ru/v2
# Public origin used to build Success/Fail/Notification URLs sent to T-Bank.
# Defaults to https://takeride.ru when empty.
PUBLIC_APP_URL=https://takeride.ru
# AddCard CheckType: NO | HOLD | 3DS | 3DSHOLD. Defaults to 3DS when empty.
# 3DS runs card binding through 3-D Secure (recommended for recurring charges).
# If a test/sandbox terminal rejects 3DS binding, set this to NO to bind without
# the 3-D Secure step for Stage 1 testing. Invalid values fall back to 3DS.
TBANK_ADD_CARD_CHECK_TYPE=3DS

